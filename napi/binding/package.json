{
  "name": "@oxc-plugin-react-compiler/binding",
  "version": "0.0.0",
  "description": "Native bindings for oxc-plugin-react-compiler",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/oxc-react-compiler.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/oxc-react-compiler.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eve0415/oxc-plugin-react-compiler.git"
  },
  "homepage": "https://github.com/eve0415/oxc-plugin-react-compiler",
  "author": "eve0415",
  "bugs": {
    "url": "https://github.com/eve0415/oxc-plugin-react-compiler/issues"
  },
  "napi": {
    "binaryName": "oxc-react-compiler",
    "packageName": "@oxc-plugin-react-compiler/binding",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "optionalDependencies": {
    "@oxc-plugin-react-compiler/binding-darwin-x64": "0.0.0",
    "@oxc-plugin-react-compiler/binding-darwin-arm64": "0.0.0",
    "@oxc-plugin-react-compiler/binding-linux-x64-gnu": "0.0.0",
    "@oxc-plugin-react-compiler/binding-linux-arm64-gnu": "0.0.0",
    "@oxc-plugin-react-compiler/binding-win32-x64-msvc": "0.0.0"
  }
}

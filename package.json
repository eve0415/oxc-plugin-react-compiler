{
  "type": "module",
  "imports": {
    "#binding": "./napi/dist/index.js",
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx"
    ]
  },
  "scripts": {
    "prebuild": "pnpm exec napi build --platform --release --esm -p oxc_react_compiler_napi --package-json-path napi/package.json -o napi/dist",
    "fix": "vp lint --type-aware --type-check --fix --fix-suggestions --fix-dangerously && vp fmt",
    "prepare": "vp config",
    "bump": "node scripts/bump-version.ts"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@napi-rs/cli": "^3.6.0",
    "@rolldown/plugin-babel": "0.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "^8.58.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "acorn": "8.16.0",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
    "vite-plus": "0.1.15",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14"
  },
  "devEngines": {
    "packageManager": [
      {
        "name": "pnpm",
        "version": "10.33.0"
      },
      {
        "name": "npm"
      }
    ],
    "runtime": {
      "name": "node",
      "version": "24.14.x"
    }
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14"
    }
  }
}

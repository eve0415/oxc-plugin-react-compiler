{
  "type": "module",
  "imports": {
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx"
    ]
  },
  "scripts": {
    "prebuild": "vpx napi build --platform --release --cwd crates/oxc_react_compiler_napi -o napi/binding/dist",
    "fix": "vp lint --type-aware --type-check --fix --fix-suggestions --fix-dangerously && vp fmt",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@napi-rs/cli": "^3.5.1",
    "@rolldown/plugin-babel": "0.2.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260322.1",
    "acorn": "8.16.0",
    "babel-plugin-react-compiler": "1.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.13",
    "vite-plus": "0.1.13",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.13"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "10.32.1"
    },
    "runtime": {
      "name": "node",
      "version": "24.14.x"
    }
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.13",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.13"
    }
  }
}
